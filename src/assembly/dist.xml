<?xml version="1.0" encoding="UTF-8"?>
<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3 http://maven.apache.org/xsd/assembly-1.1.3.xsd">
  <fileSets>
    <fileSet>
      <directory>${project.build.directory}/liberty/wlp</directory>
      <outputDirectory>wlp</outputDirectory>
      <excludes>
        <exclude>usr/servers/**</exclude>
      </excludes>
    </fileSet>
    <fileSet>
      <directory>src/main/liberty/config</directory>
      <outputDirectory>wlp/usr/servers/defaultServer</outputDirectory>
    </fileSet>
    <fileSet>
      <directory>target</directory>
      <outputDirectory>wlp/usr/servers/defaultServer/apps</outputDirectory>
      <includes>
        <include>${project.artifactId}.war</include>
      </includes>
    </fileSet>
  </fileSets>
</assembly>
